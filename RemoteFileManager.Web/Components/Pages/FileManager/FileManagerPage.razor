@page "/"
@using RemoteFileManager.Web.Services
@inject FileSystemService Fs
@inject SelectionManager Selection

<PageTitle>@CurrentParent</PageTitle>

<MudToolBar Gutters="false">
    <MudIconButton OnClick="NavigateUp" Icon="@Icons.Material.Filled.ArrowUpward"/>

    @if (ShowBreadcrumbs)
    {
        <MudBreadcrumbs Items="breadcrumbItems">
            <ItemTemplate Context="item">
                <MudLink OnClick="() => OpenDirectory(item.Href)">@item.Text</MudLink>
            </ItemTemplate>
        </MudBreadcrumbs>
    }
    else
    {
        <MudTextField Variant="Variant.Outlined"
                      Label="Current Directory"
                      @bind-Value="CurrentPath"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Forward"
                      OnAdornmentClick="LoadCurrent"/>
    }

    <MudTooltip Text="Show Breadcrumbs">
        <MudToggleIconButton @bind-Toggled="@ShowBreadcrumbs" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Link"
                             ToggledIcon="@Icons.Material.Filled.LinkOff" />
    </MudTooltip>

    <MudTooltip Text="Show hidden files">
        <MudToggleIconButton @bind-Toggled="@ShowHidden" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Visibility"
                             ToggledIcon="@Icons.Material.Filled.VisibilityOff" />
    </MudTooltip>

    <MudButtonGroup OverrideStyles="false">
        <MudTooltip Text="Grid View">
            <MudIconButton Variant="Variant.Outlined" Icon="@Icons.Material.Filled.GridView"
                           Color="CurrentLayout == Layout.Grid ? Color.Primary : Color.Surface"
                           OnClick="() => CurrentLayout = Layout.Grid" />
        </MudTooltip>

        <MudTooltip Text="Table View">
            <MudIconButton Variant="Variant.Outlined" Icon="@Icons.Material.Filled.TableChart"
                           Color="CurrentLayout == Layout.Table ? Color.Primary : Color.Surface"
                           OnClick="() => CurrentLayout = Layout.Table" />
        </MudTooltip>
        <MudTooltip Text="List View">
            <MudIconButton Variant="Variant.Outlined" Icon="@Icons.Material.Filled.ViewList"
                           Color="CurrentLayout == Layout.List ? Color.Primary : Color.Surface"
                           OnClick="() => CurrentLayout = Layout.List" />
        </MudTooltip>
    </MudButtonGroup>
</MudToolBar>

<MudToolBar>
    
    <MudTooltip Text="Info">
        <MudIconButton Icon="@Icons.Material.Filled.Info" OnClick="InfoClicked"/>
    </MudTooltip>

    <MudTooltip Text="Delete">
        <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="DeleteClicked"/>
    </MudTooltip>

    <MudTooltip Text="New Folder">
        <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder" OnClick="CreateNewFolder"/>
    </MudTooltip>

    <MudTooltip Text="Refresh">
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="Refresh"/>
    </MudTooltip>

    <MudTooltip Text="Deselect (Esc)">
        <MudIconButton Icon="@Icons.Material.Filled.Deselect" OnClick="EscapePressed"/>
    </MudTooltip>

    <MudTooltip Text="Rename (F2)">
        <MudIconButton Icon="@Icons.Material.Filled.DriveFileRenameOutline" OnClick="RenameSelected"/>
    </MudTooltip>

    <MudTooltip Text="Cut">
        <MudIconButton Icon="@Icons.Material.Filled.ContentCut" OnClick="CutSelected"/>
    </MudTooltip>

    <MudTooltip Text="Copy">
        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="CopySelected"/>
    </MudTooltip>

    <MudTooltip Text="Paste">
        <MudIconButton Icon="@Icons.Material.Filled.ContentPasteGo" OnClick="PasteSelected"/>
    </MudTooltip>

    <MudTooltip Text="Clear Clipboard">
        <MudIconButton Icon="@Icons.Material.Filled.LayersClear" OnClick="ClearClipboard"/>
    </MudTooltip>
</MudToolBar>

<br/>
@CurrentParent: @Contents.Count(x => x is DirectoryInfo) folders, @Contents.Count(x => x is FileInfo) files | 

@Selection.Selected.Count selected |

@Fs.Clipboard.Count items in clipboard
<br/>

@switch (CurrentLayout)
{
    case Layout.List:
        <FileListView
            Contents="Contents"
            IsRoot="IsRoot"
            NavigateUp="NavigateUp"
            OpenDirectory="OpenDirectory"/>
        break;
    case Layout.Grid:
        <FileGridView
            Contents="Contents"
            OpenDirectory="OpenDirectory"/>
        break;
    case Layout.Table:
        <FileTableView
            Contents="Contents"
            OpenDirectory="OpenDirectory"/>
        break;
}

@code {

    bool ShowBreadcrumbs = true;

    List<BreadcrumbItem> breadcrumbItems
    {
        get
        {
            var root = Path.GetPathRoot(CurrentPath)!;
            var parts = CurrentPath[root.Length..]
                .Split(Path.DirectorySeparatorChar, StringSplitOptions.RemoveEmptyEntries);

            var path = root;

            return parts.Select(p =>
            {
                path = Path.Combine(path, p);
                return new BreadcrumbItem(p, path, false, null);
            }).Prepend(new BreadcrumbItem(root, root, false, null)).ToList();
        }
    }

    void OpenDirectory(string path)
    {
        Selection.Clear();
        CurrentPath = path;
        LoadCurrent();
    }

    string CurrentParent =>
        string.IsNullOrWhiteSpace(Path.GetFileName(CurrentPath))
            ? "Root"
            : Path.GetFileName(CurrentPath);

    enum Layout
    {
        Grid,
        List,
        Table
    }

    Layout CurrentLayout = Layout.Table;
    
    protected override void OnInitialized()
    {
        Selection.Changed += StateHasChanged;
    }

    public void Dispose()
    {
        Selection.Changed -= StateHasChanged;
    }

    bool ShowHidden
    {
        get => field;
        set
        {
            field = value;
            LoadCurrent();
        }
    }

    bool IsRoot =>
        Path.GetFullPath(CurrentPath) ==
        Path.GetFullPath(Directory.GetDirectoryRoot(CurrentPath)!);

    string CurrentPath = Directory.GetDirectoryRoot(Environment.CurrentDirectory);

    List<FileSystemInfo> Contents = [];

    protected override Task OnInitializedAsync()
    {
        LoadCurrent();
        return Task.CompletedTask;
    }

    void LoadCurrent()
    {
        try
        {
            Selection.Clear();
            Contents = Fs.GetDirectoryContents(CurrentPath, ShowHidden);
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add($"Access denied to {CurrentPath}", Severity.Warning);
            NavigateUp();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    void NavigateUp()
    {
        if (IsRoot) return;

        Selection.Clear();
        CurrentPath = Directory.GetParent(CurrentPath)?.FullName ?? CurrentPath;
        LoadCurrent();
    }

    private void EscapePressed()
    {
        Selection.Clear();
    }

    async Task DeleteClicked()
    {
        if (Selection.Selected.Count == 0) return;

        var message = Selection.Selected.Count == 1
            ? $"Delete {Path.GetFileName(Selection.Selected.First())}?"
            : $"Delete {Selection.Selected.Count} items?";

        var res = await DialogService.ShowMessageBoxAsync("Delete", message, "Yes", "No");

        if (res != true) return;

        var results = Fs.Delete(Selection.Selected);

        foreach (var r in results.Where(x => !x.Success))
            Snackbar.Add(r.Error, Severity.Error);

        Selection.Clear();
        LoadCurrent();
    }

    private void Refresh()
    {
        LoadCurrent();
    }

    private async Task CreateNewFolder()
    {
        var existing = Fs.GetNames(CurrentPath);

        string baseName = "New Folder";
        string name = baseName;
        int i = 2;

        while (existing.Contains(name))
        {
            name = $"{baseName} ({i})";
            i++;
        }

        var dialog = await DialogService.ShowAsync<TextPromptDialog>(
            "New Folder",
            new DialogParameters<TextPromptDialog>
            {
                { x => x.InitialValue, name },
                { x => x.Label, "New name" },
                { x => x.DisallowedValues, existing }
            });

        var result = await dialog.Result;

        if (result?.Canceled == true) return;
        if (result?.Data is not string newName) return;

        var op = Fs.CreateFolder(CurrentPath, newName);

        if (!op.Success)
            Snackbar.Add(op.Error, Severity.Error);

        LoadCurrent();
    }

    private async void RenameSelected()
    {
        if (Selection.Selected.Count != 1)
        {
            Snackbar.Add("Select exactly one item.", Severity.Warning);
            return;
        }

        var path = Selection.Selected.First();

        var existing = Fs.GetNames(CurrentPath);

        var dialog = await DialogService.ShowAsync<TextPromptDialog>(
            "Rename",
            new DialogParameters<TextPromptDialog>
            {
                { x => x.InitialValue, Path.GetFileName(path) },
                { x => x.Label, "New name" },
                { x => x.DisallowedValues, existing }
            });

        var result = await dialog.Result;

        if (result?.Canceled == true) return;
        if (result?.Data is not string newName) return;

        var op = Fs.Rename(path, newName);

        if (!op.Success)
            Snackbar.Add(op.Error, Severity.Error);

        Selection.Clear();
        LoadCurrent();
    }

    private void CopySelected()
    {
        if (Selection.Selected.Count == 0) return;

        Fs.Copy(Selection.Selected);

        Snackbar.Add($"{Selection.Selected.Count} item(s) copied", Severity.Info);
    }

    private void CutSelected()
    {
        if (Selection.Selected.Count == 0) return;

        Fs.Cut(Selection.Selected);

        Snackbar.Add($"{Selection.Selected.Count} item(s) cut", Severity.Info);
    }

    private void PasteSelected()
    {
        var results = Fs.Paste(CurrentPath);

        foreach (var r in results.Where(x => !x.Success))
            Snackbar.Add(r.Error, Severity.Error);

        Selection.Clear();
        LoadCurrent();
    }

    private void ClearClipboard()
    {
        Fs.ClearClipboard();
    }

    private async Task InfoClicked()
    {
        if (Selection.Selected.Count != 1)
        {
            Snackbar.Add("Select exactly one item.", Severity.Warning);
            return;
        }

        var path = Selection.Selected.Single();

        FileSystemInfo info;
    
        if (Directory.Exists(path))
            info = new DirectoryInfo(path);
        else if (File.Exists(path))
            info = new FileInfo(path);
        else
        {
            Snackbar.Add("Item no longer exists.", Severity.Warning);
            LoadCurrent();
            return;
        }

        await DialogService.ShowAsync<InfoDialog>(
            "Properties",
            new DialogParameters<InfoDialog>
            {
                { x => x.FileSystemInfo, info }
            });
    }

}